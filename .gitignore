# ---------------------------------------------------------------------------
# Secrets / local config
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.eggs/
build/
dist/
wheels/
pip-wheel-metadata/
.installed.cfg

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Test / type-check / coverage caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyright/
.hypothesis/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/

# Jupyter
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Rust (harnesses/rust and any ad-hoc Cargo projects)
# ---------------------------------------------------------------------------
target/
**/target/
# Keep Cargo.lock for binaries/harnesses (it lives at harnesses/rust/Cargo.lock)
*.rs.bk

# ---------------------------------------------------------------------------
# Free Pascal / Delphi build artefacts
# ---------------------------------------------------------------------------
*.o
*.a
*.ppu
*.rsj
*.or
*.compiled
*.dcu
*.lps
*.lpi.bak
# Compiled binaries in harnesses/pascal (names vary, so be generous)
harnesses/pascal/lip_harness
harnesses/pascal/lip_harness.exe
harnesses/pascal/*.bin

# ---------------------------------------------------------------------------
# Paper (LaTeX sources + build artefacts)
# ---------------------------------------------------------------------------
paper/

# ---------------------------------------------------------------------------
# Large experiment outputs (regeneratable from the versions/ JSONs)
# ---------------------------------------------------------------------------
# Per-case campaign results can exceed 4 GB each — keep them out of git.
campaign.csv
results/**/campaign.csv

# ---------------------------------------------------------------------------
# Agent / experiment scratch
# ---------------------------------------------------------------------------
# Sandboxes generated per-run (generate_versions.py). These normally live in
# /tmp, but ignore in-tree ones too.
nvp_*/
sandboxes/

# ---------------------------------------------------------------------------
# OS / editor / tooling
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Node (in case any tooling introduces it)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------------------------------------------------------------------
# Logs / misc
# ---------------------------------------------------------------------------
*.log
logs/

fault_events.jsonl